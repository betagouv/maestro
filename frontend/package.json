{
  "name": "maestro-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cp -r ../node_modules/@codegouvfr ./node_modules/ && react-dsfr update-icons && vite",
    "start": "react-dsfr update-icons && vite",
    "tsc": "tsc",
    "build": "react-dsfr update-icons && tsc && vite build",
    "build-vite": "vite build",
    "scalingo-postbuild": "run-p build-vite build-storybook",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "biome check",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "license": "AGPL-3.0",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@codegouvfr/react-dsfr": "^1.32.1",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.0.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@sentry/react": "^10.51.0",
    "@sentry/vite-plugin": "^5.2.1",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react-vite": "^10.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "clsx": "^2.1.0",
    "i18next": "^26.0.8",
    "maestro-shared": "^0.0.1",
    "maplibre-gl": "^5.24.0",
    "playwright": "^1.59.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^16.5.4",
    "react-map-gl": "^8.1.1",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router": "^7.14.1",
    "sass": "^1.99.0",
    "storybook": "^10.3.5",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.3.0"
  },
  "overrides": {
    "vite": "$vite"
  }
}
