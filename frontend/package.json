{
  "name": "maestro-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cp -r ../node_modules/@codegouvfr ./node_modules/ && react-dsfr update-icons && vite",
    "start": "react-dsfr update-icons && vite",
    "tsc": "tsc",
    "build": "react-dsfr update-icons && tsc && vite build",
    "build-vite": "vite build",
    "scalingo-postbuild": "run-p build-vite build-storybook",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "biome check",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "license": "AGPL-3.0",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@codegouvfr/react-dsfr": "^1.32.4",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.1.0",
    "@reduxjs/toolkit": "^2.12.0",
    "@sentry/react": "^10.58.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@storybook/addon-vitest": "^10.4.3",
    "@storybook/react-vite": "^10.4.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "clsx": "^2.1.0",
    "i18next": "^26.3.1",
    "maestro-shared": "^0.0.1",
    "maplibre-gl": "^5.24.0",
    "playwright": "^1.60.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-map-gl": "^8.1.1",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.3.0",
    "react-router": "^7.17.0",
    "sass": "^1.101.0",
    "storybook": "^10.4.6",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0"
  },
  "overrides": {
    "vite": "$vite"
  }
}
