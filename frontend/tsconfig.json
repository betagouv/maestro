{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "es6",
    "lib": ["dom", "dom.iterable", "esnext"],
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noUnusedLocals": false,
    "types": ["vite/client", "node"],
    "paths": {
      "*": ["./*"]
    }
  },
  "include": [
    "src",
    "test",
    ".storybook",
    "../test/vitest-random-seed.ts",
    "vite-env.d.ts"
  ]
}
