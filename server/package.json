{
  "name": "maestro-server",
  "version": "0.0.1",
  "main": "./index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "npm run migrate-latest && node --enable-source-maps --import @swc-node/register/esm-register --watch --watch-kill-signal SIGINT --inspect ./index.ts",
    "build": "tsc",
    "tsc": "tsc",
    "start": "npm run migrate-latest && node --enable-source-maps --import ./sentry.mjs --import @swc-node/register/esm-register ./index.ts",
    "test": "vitest",
    "test:integration": "vitest --project integration",
    "test:unit": "vitest --project unit",
    "lint": "biome check",
    "migrate-list": "NODE_OPTIONS='--enable-source-maps --import @swc-node/register/esm-register' knex migrate:list",
    "migrate-latest": "NODE_OPTIONS='--enable-source-maps --import @swc-node/register/esm-register' knex migrate:latest",
    "migrate-rollback-one": "NODE_OPTIONS='--enable-source-maps --import @swc-node/register/esm-register' knex migrate:down",
    "migrate-rollback-all": "NODE_OPTIONS='--enable-source-maps --import @swc-node/register/esm-register' knex migrate:rollback --all",
    "seed": "node --enable-source-maps --import @swc-node/register/esm-register database/seeds/dummy/index.ts",
    "seed:laboratories": "node --enable-source-maps --import @swc-node/register/esm-register database/seeds/laboratories/script.ts",
    "ssd2-generate": "node --enable-source-maps --import @swc-node/register/esm-register ./scripts/updateSSD2Referential.ts",
    "check:emails": "node --enable-source-maps --import @swc-node/register/esm-register ./services/imapService/script.ts",
    "sendDAI": "node --enable-source-maps --import @swc-node/register/esm-register ./scripts/sendDAI.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@e965/xlsx": "^0.20.3",
    "@gouvfr/dsfr": "^1.14.4",
    "@sentry/node": "^10.49.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.33",
    "bwip-js": "^4.9.2",
    "carbone": "^3.8.2",
    "compose-middleware": "^5.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-jwt": "^8.5.1",
    "express-rate-limit": "^8.3.2",
    "fast-xml-builder": "^1.1.8",
    "fast-xml-parser": "^5.7.3",
    "handlebars": "^4.7.9",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "imapflow": "^1.3.1",
    "jsonwebtoken": "^9.0.0",
    "knex": "^3.1.0",
    "knex-stringcase": "^1.6.0",
    "kysely": "^0.28.14",
    "libxml2-wasm": "^0.6.0",
    "maestro-shared": "^0.0.1",
    "mailparser": "^3.9.8",
    "nodemailer": "^8.0.5",
    "openid-client": "^6.8.3",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "puppeteer-core": "^24.41.0",
    "sanitize-html": "^2.17.3",
    "ssh2-sftp-client": "^12.1.1"
  },
  "devDependencies": {
    "@types/carbone": "^3.2.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.12",
    "@types/exceljs": "^1.3.2",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^8.5.5",
    "@types/mailparser": "^3.4.5",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4"
  }
}
