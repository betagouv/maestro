{
  "name": "maestro-server",
  "version": "0.0.1",
  "main": "./index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "npm run migrate-latest && node --enable-source-maps --max-semi-space-size=16 --import ./loaders/register.mjs --watch --watch-kill-signal SIGINT --inspect ./index.ts",
    "build": "tsc",
    "tsc": "tsc",
    "start": "npm run migrate-latest && node --enable-source-maps --max-semi-space-size=16 --import ./sentry.mjs --import ./loaders/register.mjs ./index.ts",
    "test": "vitest",
    "test:integration": "vitest --project integration",
    "test:unit": "vitest --project unit",
    "lint": "biome check",
    "migrate-list": "NODE_OPTIONS='--enable-source-maps --import ./loaders/register.mjs' knex migrate:list",
    "migrate-latest": "NODE_OPTIONS='--enable-source-maps --import ./loaders/register.mjs' knex migrate:latest",
    "migrate-rollback-one": "NODE_OPTIONS='--enable-source-maps --import ./loaders/register.mjs' knex migrate:down",
    "migrate-rollback-all": "NODE_OPTIONS='--enable-source-maps --import ./loaders/register.mjs' knex migrate:rollback --all",
    "seed": "node --enable-source-maps --import ./loaders/register.mjs database/seeds/dummy/index.ts",
    "seed:laboratories": "node --enable-source-maps --import ./loaders/register.mjs database/seeds/laboratories/script.ts",
    "ssd2-generate": "node --enable-source-maps --import ./loaders/register.mjs ./scripts/updateSSD2Referential.ts",
    "check:emails": "node --enable-source-maps --import ./loaders/register.mjs ./services/imapService/script.ts",
    "sendDAI": "node --enable-source-maps --import ./loaders/register.mjs ./scripts/sendDAI.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1076.0",
    "@aws-sdk/s3-request-presigner": "^3.1077.0",
    "@e965/xlsx": "^0.20.3",
    "@gouvfr/dsfr": "^1.14.4",
    "@sentry/node": "^10.62.0",
    "bwip-js": "^4.11.1",
    "carbone": "^3.8.2",
    "compose-middleware": "^5.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parse": "^7.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-jwt": "^8.5.1",
    "express-rate-limit": "^8.5.2",
    "fast-xml-builder": "^1.1.9",
    "fast-xml-parser": "^5.9.3",
    "handlebars": "^4.7.9",
    "helmet": "^8.2.0",
    "http-proxy-middleware": "^4.1.1",
    "imapflow": "^1.4.3",
    "jsonwebtoken": "^9.0.0",
    "knex": "^3.3.0",
    "knex-stringcase": "^1.6.0",
    "kysely": "^0.29.2",
    "libxml2-wasm": "^0.7.1",
    "maestro-shared": "^0.0.1",
    "mailparser": "^3.9.12",
    "nodemailer": "^9.0.1",
    "openid-client": "^6.8.4",
    "pdf-lib": "^1.17.1",
    "pg": "^8.22.0",
    "puppeteer-core": "^25.2.1",
    "sanitize-html": "^2.17.5",
    "ssh2-sftp-client": "^12.1.1"
  },
  "devDependencies": {
    "@types/carbone": "^3.2.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.12",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mailparser": "^3.4.5",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2"
  }
}
