{
  "name": "Maestro",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/betagouv/maestro.git"
  },
  "workspaces": [
    "shared",
    "server",
    "frontend"
  ],
  "license": "AGPL-3.0",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "start-local": "run-p server-local frontend-local",
    "server-local": "npm run dev -w server",
    "frontend-local": "npm run dev -w frontend",
    "start": "npm run start -w server",
    "scalingo-postbuild": "npm run --workspaces --if-present scalingo-postbuild",
    "lint": "biome check",
    "knip": "npx --yes knip@6.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/uuid": "^10.0.0",
    "lefthook": "^2.1.4",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "lodash-es": "^4.18.1",
    "tsafe": "^1.8.12",
    "uuid": "^11.0.5",
    "zod": "^4.3.6"
  },
  "release": {
    "branches": [
      "prod",
      {
        "name": "prod",
        "prerelease": false
      }
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/github",
      "semantic-release-mattermost"
    ]
  }
}
